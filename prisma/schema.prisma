// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Marketing Models ───

model Campana {
  id            String    @id @default(cuid())
  titulo        String
  tipo          String    // push, email, sms
  segmento      String    // todos, frecuentes, inactivos, nuevos, vip, personalizado
  contenido     String    // JSON con titulo, cuerpo, boton, etc.
  estado        String    @default("borrador") // borrador, programada, enviada, fallida
  programadaPara DateTime?
  enviadaEn     DateTime?
  destinatarios Int       @default(0)
  abiertos      Int       @default(0)
  clicks        Int       @default(0)
  creadoPor     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CodigoPromocional {
  id             String   @id @default(cuid())
  codigo         String   @unique
  tipoDescuento  String   // porcentaje, monto
  valor          Float
  aplicableA     String   // todos, primer_envio, envio_minimo
  montoMinimo    Float?
  maxUsos        Int      @default(0) // 0 = ilimitado
  usosActuales   Int      @default(0)
  segmento       String   @default("todos")
  vigenciaInicio DateTime
  vigenciaFin    DateTime
  estado         String   @default("activo")
  creadoPor      String
  createdAt      DateTime @default(now())
}

model UsoCodigo {
  id        String   @id @default(cuid())
  codigoId  String
  clienteId String
  ordenId   String?
  descuento Float
  usadoEn   DateTime @default(now())
}

model Banner {
  id              String   @id @default(cuid())
  titulo          String
  subtitulo       String?
  tipo            String   // promo_grande, tarjeta_compacta, slider, notificacion
  colorFondo      String   @default("#FF5722")
  gradiente       String?  // JSON {from, to, direction}
  colorTexto      String   @default("#FFFFFF")
  imagenUrl       String?
  botonTexto      String?
  botonAccion     String?
  botonLink       String?
  icono           String?
  segmento        String   @default("todos")
  mostrarEn       String   @default("app") // app, dashboard, ambos
  posicion        Int      @default(0)
  estado          String   @default("activo")
  impresiones     Int      @default(0)
  clicks          Int      @default(0)
  programadoDesde DateTime?
  programadoHasta DateTime?
  creadoPor       String
  createdAt       DateTime @default(now())
}

model FeedItem {
  id          String   @id @default(cuid())
  tipo        String   // anuncio, promocion, novedad, encuesta, recordatorio
  titulo      String
  descripcion String
  icono       String?
  botonTexto  String?
  botonLink   String?
  codigoPromo String?
  segmento    String   @default("todos")
  posicion    Int      @default(0)
  estado      String   @default("activo")
  impresiones Int      @default(0)
  clicks      Int      @default(0)
  creadoPor   String
  createdAt   DateTime @default(now())
}

model PlantillaMensaje {
  id        String   @id @default(cuid())
  nombre    String
  categoria String   // orden, incidencia, promocion, general
  contenido String
  variables String   // JSON array string
  esDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MensajeDirecto {
  id          String   @id @default(cuid())
  emisorId    String
  receptorId  String
  contenido   String
  leido       Boolean  @default(false)
  enviadoEn   DateTime @default(now())
}

model NotificacionAutomatica {
  id           String  @id @default(cuid())
  evento       String  // orden_creada, orden_entregada, etc
  etiqueta     String
  activa       Boolean @default(true)
  canal        String  // push, email, sms, todos
  plantilla    String
  destinatario String  // cliente, repartidor, admin, ingeniero
}

// ─── Config Models ───

model ConfiguracionHorario {
  id              String  @id @default(cuid())
  dia             Int     // 0-6 (domingo a sabado)
  horaInicio      String  // "07:00"
  horaFin         String  // "20:00"
  activo          Boolean @default(true)
  recargoNocturno Float   @default(0)
}

model Feriado {
  id      String   @id @default(cuid())
  fecha   DateTime
  nombre  String
  recargo Float    @default(0)
}

// ─── SuperAdmin Models ───

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  accion      String
  recurso     String
  recursoId   String?
  detalles    String?
  ip          String?
  dispositivo String?
  createdAt   DateTime @default(now())
}

model FeatureFlag {
  id          String  @id @default(cuid())
  nombre      String
  descripcion String
  habilitado  Boolean @default(false)
}

// ─── Marketplace Models ───

model Tienda {
  id            String   @id @default(cuid())
  nombre        String
  descripcion   String?
  categoria     String   // comida, tienda, farmacia, regalos, supermercado, tecnologia, deportes
  logoColor     String   @default("#FF5722")
  logoIniciales String
  portadaColor  String   @default("#1B1B2F")
  direccion     String
  lat           Float
  lng           Float
  telefono      String?
  email         String?
  calificacion  Float    @default(0)
  totalPedidos  Int      @default(0)
  tiempoEstimado String  @default("25-35 min")
  costoEnvio    Float    @default(20)
  pedidoMinimo  Float    @default(50)
  horario       String   // JSON
  zonaCobertura String   @default("[]") // JSON array
  verificado    Boolean  @default(false)
  popular       Boolean  @default(false)
  estado        String   @default("activo")
  propietarioId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  productos     Producto[]
  resenas       ResenaTienda[]
  favoritos     FavoritoTienda[]
  ordenes       OrdenCompra[]
}

model Producto {
  id             String   @id @default(cuid())
  tiendaId       String
  categoriaNombre String? // "Entradas", "Platos fuertes", etc.
  nombre         String
  descripcion    String?
  precio         Float
  precioOriginal Float?
  imagenColor    String   @default("#E8E4DE")
  disponible     Boolean  @default(true)
  esNuevo        Boolean  @default(false)
  esPopular      Boolean  @default(false)
  stock          Int?
  posicion       Int      @default(0)
  createdAt      DateTime @default(now())

  tienda         Tienda  @relation(fields: [tiendaId], references: [id])
  favoritos      FavoritoProducto[]
  itemsOrden     ItemOrdenCompra[]
}

model OrdenCompra {
  id              String   @id @default(cuid())
  clienteId       String
  tiendaId        String
  repartidorId    String?
  estado          String   @default("recibido")
  direccionEntrega String
  lat             Float    @default(0)
  lng             Float    @default(0)
  instrucciones   String?
  metodoPago      String   @default("efectivo")
  subtotal        Float
  costoEnvio      Float
  descuento       Float    @default(0)
  codigoUsado     String?
  total           Float
  programadoPara  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tienda          Tienda            @relation(fields: [tiendaId], references: [id])
  items           ItemOrdenCompra[]
  resenas         ResenaTienda[]
}

model ItemOrdenCompra {
  id             String  @id @default(cuid())
  ordenId        String
  productoId     String
  nombreProducto String
  cantidad       Int
  precioUnitario Float
  variante       String?
  notas          String?

  orden          OrdenCompra @relation(fields: [ordenId], references: [id])
  producto       Producto   @relation(fields: [productoId], references: [id])
}

model FavoritoTienda {
  id        String   @id @default(cuid())
  clienteId String
  tiendaId  String
  createdAt DateTime @default(now())

  tienda    Tienda @relation(fields: [tiendaId], references: [id])
}

model FavoritoProducto {
  id         String   @id @default(cuid())
  clienteId  String
  productoId String
  createdAt  DateTime @default(now())

  producto   Producto @relation(fields: [productoId], references: [id])
}

model ResenaTienda {
  id         String   @id @default(cuid())
  tiendaId   String
  clienteId  String
  ordenId    String?
  estrellas  Int
  comentario String?
  createdAt  DateTime @default(now())

  tienda     Tienda @relation(fields: [tiendaId], references: [id])
  orden      OrdenCompra? @relation(fields: [ordenId], references: [id])
}

// ─── Repartidor Models ───

model RepartidorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  nombre          String
  email           String
  telefono        String?
  motoId          String?
  conectado       Boolean  @default(false)
  enServicio      Boolean  @default(false)
  pausado         Boolean  @default(false)
  pausaHasta      DateTime?
  lat             Float?
  lng             Float?
  zonaPreferida   String?
  calificacion    Float    @default(0)
  totalEntregas   Int      @default(0)
  totalKm         Float    @default(0)
  totalGanancias  Float    @default(0)
  tiempoPromedio  Int      @default(0)
  sonidoActivo    Boolean  @default(true)
  vibracionActiva Boolean  @default(true)
  ubicacionActiva Boolean  @default(true)
  rechazosHora    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PosicionRepartidor {
  id           String   @id @default(cuid())
  repartidorId String
  lat          Float
  lng          Float
  velocidad    Float    @default(0)
  heading      Float    @default(0)
  timestamp    DateTime @default(now())

  @@index([repartidorId, timestamp])
}

model ServicioRepartidor {
  id              String    @id @default(cuid())
  repartidorId    String
  ordenId         String
  tipo            String    // envio, compra
  estado          String    // asignado, aceptado, recogido, entregado, incidencia, cancelado
  kmRecorridos    Float     @default(0)
  kmEstimados     Float     @default(0)
  tiempoTotal     Int       @default(0)
  ganancia        Float     @default(0)
  incidenciaTipo  String?
  incidenciaDesc  String?
  aceptadoEn      DateTime?
  recogidoEn      DateTime?
  entregadoEn     DateTime?
  createdAt       DateTime  @default(now())

  @@index([repartidorId, createdAt])
  @@index([estado])
}

model CalificacionRepartidor {
  id           String   @id @default(cuid())
  repartidorId String
  clienteId    String
  servicioId   String
  ordenId      String
  estrellas    Int
  etiquetas    String   @default("[]") // JSON array string
  comentario   String?
  createdAt    DateTime @default(now())

  @@index([repartidorId, createdAt])
}

model MotoAsignada {
  id                  String   @id @default(cuid())
  repartidorId        String   @unique
  nombre              String
  modelo              String
  placa               String
  kmAcumulados        Float    @default(0)
  estado              String   @default("DISPONIBLE") // DISPONIBLE, EN_SERVICIO, MANTENIMIENTO
  ultimoMantenimiento DateTime?
  tipoUltimoMantenimiento String?
  proximoMantenimientoKm Float?
  alertaMantenimiento Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model NotificacionRepartidor {
  id           String   @id @default(cuid())
  repartidorId String
  tipo         String   // orden_asignada, mensaje, entrega_calificada, incidencia, cancelacion, reasignacion
  titulo       String
  contenido    String
  leido        Boolean  @default(false)
  ordenId      String?
  createdAt    DateTime @default(now())

  @@index([repartidorId, createdAt])
}

model ChatRepartidor {
  id          String   @id @default(cuid())
  ordenId     String
  repartidorId String
  clienteId   String
  emisor      String   // repartidor, cliente
  contenido   String
  leido       Boolean  @default(false)
  enviadoEn   DateTime @default(now())

  @@index([ordenId, enviadoEn])
}
